{
  "vim_mode": true,
  "vim": {
    "default_mode": "normal",
    "use_system_clipboard": "always",
    "use_regex_search": true,
    "gdefault": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 200
  },
  "which_key": {
    "enabled": true
  },
  "ui_font_size": 18,
  "ui_font_family": "Moralerspace Argon NF",
  "buffer_font_size": 18,
  "buffer_font_family": "Moralerspace Argon NF",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha"
  },
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "editor_width",
  "current_line_highlight": "all",
  "relative_line_numbers": "enabled",
  "show_whitespaces": "all",
  "whitespace_map": {
    "space": "·",
    "tab": "→"
  },
  "gutter": {
    "line_numbers": true,
    "runnables": true,
    "breakpoints": true,
    "folds": true,
    "min_line_number_digits": 4
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_text": true,
    "selected_symbol": true,
    "diagnostics": "all",
    "axes": {
      "horizontal": true,
      "vertical": true
    }
  },
  "project_panel": {
    "dock": "right",
    "default_width": 280,
    "entry_spacing": "standard",
    "git_status": true,
    "auto_reveal_entries": true,
    "auto_fold_dirs": false,
    "hide_hidden": false,
    "starts_open": true,
    "indent_guides": {
      "show": "always"
    },
    "sort_mode": "directories_first"
  },
  "terminal": {
    "shell": {
      "program": "/bin/zsh"
    },
    "working_directory": "current_project_directory"
  },
  "format_on_save": "on",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": false
    }
  },
  "document_folding_ranges": "off",
  "document_symbols": "off",
  "use_smartcase_search": true,
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemas": {
            "https://json.schemastore.org/github-workflow.json": "/.github/workflows/*",
            "https://gitlab.com/gitlab-org/gitlab/-/raw/master/app/assets/javascripts/editor/schema/ci.json": "*.gitlab-ci.yml",
            "https://raw.githubusercontent.com/awslabs/goformation/master/schema/sam.schema.json": "template.yaml"
          }
        }
      }
    }
  },
  "languages": {
    "CSS": {
      "format_on_save": "on"
    },
    "GraphQL": {
      "format_on_save": "on"
    },
    "HTML": {
      "format_on_save": "on"
    },
    "JavaScript": {
      "format_on_save": "on"
    },
    "JSON": {
      "format_on_save": "on"
    },
    "JSONC": {
      "format_on_save": "on"
    },
    "Less": {
      "format_on_save": "on"
    },
    "Lua": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "/opt/homebrew/bin/stylua",
          "arguments": [
            "--syntax=Lua54",
            "--respect-ignores",
            "--stdin-filepath",
            "{buffer_path}",
            "-"
          ]
        }
      }
    },
    "Markdown": {
      "format_on_save": "on"
    },
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true
      },
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      }
    },
    "SCSS": {
      "format_on_save": "on"
    },
    "TSX": {
      "format_on_save": "on"
    },
    "TypeScript": {
      "format_on_save": "on"
    },
    "Vue": {
      "format_on_save": "on"
    },
    "YAML": {
      "format_on_save": "on"
    }
  }
}
