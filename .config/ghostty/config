# Terminal rendering for cmux.
# cmux reads Ghostty config from ~/.config/ghostty/config.

command = /bin/zsh
theme = Catppuccin Mocha

font-family = Moralerspace Argon NF
font-size = 18
window-title-font-family = Moralerspace Argon NF

window-width = 150
window-height = 50
window-decoration = none
window-padding-x = 5
window-padding-y = 10,0
window-padding-color = background

background = #1e1e2e
background-opacity = 0.9
background-blur = 30
background-image = ~/.config/wezterm/background.jpg
background-image-opacity = 0.9
background-image-fit = cover
background-image-position = center

scrollback-limit = 50000000
split-divider-color = #6c7086
unfocused-split-opacity = 1

mouse-hide-while-typing = true
clipboard-read = allow
clipboard-write = allow
shell-integration = zsh

# Match the tmux/WezTerm workflow where cwd follows the focused pane.
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true
